{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AIResponse",
  "type": "object",
  "additionalProperties": false,
  "required": ["message"],
  "properties": {
    "message": {
      "type": "string",
      "description": "Assistant response to the user."
    },
    "updates": {
      "description": "Optional updates to apply to the board.",
      "anyOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "board": {
              "description": "Full updated board state.",
              "anyOf": [
                {"type": "null"},
                {"$ref": "#/defs/board"}
              ]
            }
          }
        }
      ]
    }
  },
  "defs": {
    "card": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "details"],
      "properties": {
        "id": {"type": "string"},
        "title": {"type": "string"},
        "details": {"type": "string"}
      }
    },
    "column": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "cardIds"],
      "properties": {
        "id": {"type": "string"},
        "title": {"type": "string"},
        "cardIds": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "board": {
      "type": "object",
      "additionalProperties": false,
      "required": ["columns", "cards"],
      "properties": {
        "columns": {
          "type": "array",
          "items": {"$ref": "#/defs/column"}
        },
        "cards": {
          "type": "object",
          "additionalProperties": {"$ref": "#/defs/card"}
        }
      }
    }
  }
}
